" ~/.vimrc — minimal vim configuration for network troubleshooting
set nocompatible
syntax on
set number
set relativenumber
set cursorline
set cursorcolumn
set showmatch
set hlsearch
set incsearch
set ignorecase
set smartcase
set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set smartindent
set ruler
set laststatus=2
set wildmenu
set scrolloff=5
set backspace=indent,eol,start
set encoding=utf-8
set fileencodings=utf-8,big5,latin1
set mouse=a
set ttimeoutlen=50

" Status line
set statusline=%F%m%r%h%w\ [%{&ff}]\ [%Y]\ [%l,%v]\ [%p%%]

" Color scheme (use built-in desert for dark terminals)
colorscheme desert
set background=dark
